{
  "name": "stacktrace-link",
  "version": "0.1.0",
  "description": "Parse Node.js stack traces and open the relevant file/line in your editor",
  "main": "dist/cli.js",
  "bin": {
    "stacktrace-link": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["stacktrace", "cli", "developer-tools", "editor"],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
